mainmenu "Zephyr Application Configuration"

menuconfig APP_LED_SUBSYSTEM
	bool "LED Subsystem"
	default n
	help
	  Enable application LED features (blink timing, advanced options).

if APP_LED_SUBSYSTEM

choice APP_LED_BLINK_SLEEP_TIME
	prompt "LED blink sleep time"
	default APP_LED_BLINK_SLEEP_1S
	help
	  Time between LED state toggles while blinking.

config APP_LED_BLINK_SLEEP_250MS
	bool "250 ms (very fast)"

config APP_LED_BLINK_SLEEP_500MS
	bool "500 ms (fast)"

config APP_LED_BLINK_SLEEP_1S
	bool "1 s (medium)"

config APP_LED_BLINK_SLEEP_2S
	bool "2 s (slow)"

endchoice

config APP_LED_BLINK_SLEEP_MS
	int
	default 250 if APP_LED_BLINK_SLEEP_250MS
	default 500 if APP_LED_BLINK_SLEEP_500MS
	default 1000 if APP_LED_BLINK_SLEEP_1S
	default 2000 if APP_LED_BLINK_SLEEP_2S

menuconfig APP_LED_ADVANCED
	bool "Advanced LED settings"
	help
	  PWM-style brightness, fade timing, and expert-only tuning.

if APP_LED_ADVANCED

config APP_LED_BRIGHTNESS
	int "LED brightness (0-100)"
	range 0 100
	default 100
	help
	  LED brightness as a percentage.

config APP_LED_FADE_MS
	int "LED fade duration (ms)"
	range 0 5000
	default 500
	help
	  Time to ramp brightness; 0 disables fading.

config APP_LED_EXPERT
	bool "Enable expert settings"
	help
	  When enabled, the Expert settings submenu is shown in menuconfig.

# Expert submenu visibility is gated by APP_LED_EXPERT (visible if below).
menu "Expert settings"
	visible if APP_LED_EXPERT

config APP_LED_DEBUG
	bool "Enable LED debugging"
	depends on APP_LED_EXPERT
	default n
	help
	  Extra runtime logging and diagnostics for LED code paths.

config APP_LED_CUSTOM_BLINK_PATTERN
	bool "Custom blink pattern"
	depends on APP_LED_EXPERT
	default n
	help
	  Application-defined encoding for a custom on/off blink sequence.

endmenu

endif # APP_LED_ADVANCED

endif # APP_LED_SUBSYSTEM

# Sources Kconfig.zephyr in the Zephyr root directory ($srctree).
source "Kconfig.zephyr"
